{
  "name": "yzcli-mcp",
  "version": "0.2.0",
  "type": "module",
  "description": "MCP Server for YZCLI ERP — SDK-based, supports stdio + HTTP transport",
  "main": "dist/index.js",
  "bin": {
    "yzcli-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "yzcli-sdk": "*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
